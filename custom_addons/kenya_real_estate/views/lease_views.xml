<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="estate_lease_view_list" model="ir.ui.view">
    <field name="name">estate.lease.list</field>
    <field name="model">estate.lease</field>
    <field name="arch" type="xml">
      <list string="Leases" decoration-success="status=='active'"
            decoration-muted="status=='expired'">
        <field name="name"/>
        <field name="property_id"/>
        <field name="tenant_id"/>
        <field name="date_start"/>
        <field name="date_end"/>
        <field name="monthly_rent"/>
        <field name="status"/>
        <field name="payment_count"/>
      </list>
    </field>
  </record>

  <record id="estate_lease_view_form" model="ir.ui.view">
    <field name="name">estate.lease.form</field>
    <field name="model">estate.lease</field>
    <field name="arch" type="xml">
      <form string="Lease">
        <header>
          <button name="action_activate" string="Activate" type="object"
                  invisible="status != 'draft'" class="oe_highlight"/>
          <button name="action_generate_rent_invoice" string="Generate Rent Invoice"
                  type="object" invisible="status != 'active'" class="btn-primary"/>
          <button name="action_cancel" string="Cancel" type="object"
                  invisible="status in ('cancelled','expired')"/>
          <field name="status" widget="statusbar"
                 statusbar_visible="draft,active,expired"/>
        </header>
        <sheet>
          <group>
            <group>
              <field name="name"/>
              <field name="property_id"/>
              <field name="tenant_id"/>
            </group>
            <group>
              <field name="date_start"/>
              <field name="date_end"/>
              <field name="monthly_rent"/>
              <field name="deposit"/>
            </group>
          </group>
          <notebook>
            <page string="Rent Invoices">
              <field name="payment_ids" readonly="1">
                <list>
                  <field name="name"/>
                  <field name="invoice_date"/>
                  <field name="amount_total"/>
                  <field name="payment_state"/>
                </list>
              </field>
            </page>
            <page string="Notes">
              <field name="notes"/>
            </page>
          </notebook>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>

  <record id="estate_lease_action" model="ir.actions.act_window">
    <field name="name">Leases</field>
    <field name="res_model">estate.lease</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
