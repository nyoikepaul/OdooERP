<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payment_provider_form_inherit" model="ir.ui.view">
        <field name="name">M-Pesa Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="after">
                <field name="mpesa_consumer_key" invisible="code != 'mpesa'"/>
                <field name="mpesa_consumer_secret" invisible="code != 'mpesa'"/>
                <field name="mpesa_shortcode" invisible="code != 'mpesa'"/>
                <field name="mpesa_passkey" invisible="code != 'mpesa'"/>
            </xpath>
        </field>
    </record>
</odoo>
